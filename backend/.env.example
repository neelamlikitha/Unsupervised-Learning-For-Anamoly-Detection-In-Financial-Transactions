PORT=4000
JWT_SECRET=super_secret_jwt_key_change_me
JWT_REFRESH_SECRET=super_secret_refresh_key_change_me
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=anomaly_detection_db

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ML thresholds (tune as needed)
ANOMALY_THRESHOLD_SUSPICIOUS=0.55
ANOMALY_THRESHOLD_HIGH_RISK=0.75

# Cron schedule for periodic model retraining (default: 2 AM daily)
RETRAIN_CRON=0 2 * * *

# Webhook URL for high-risk alert (optional – leave blank to disable)
ALERT_WEBHOOK_URL=

# CORS allowed origin
CORS_ORIGIN=http://localhost:5173

